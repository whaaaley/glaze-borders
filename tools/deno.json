{
  "tasks": {
    "commit": "deno run --allow-read commit/commit.ts",
    "test": "deno test --allow-read",
    "install-hooks": "git -C .. config core.hooksPath tools/commit/hooks"
  },
  "fmt": {
    "lineWidth": 240,
    "semiColons": false,
    "singleQuote": true,
    "exclude": ["*.md", "**/*.md"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/streams": "jsr:@std/streams@^1.1.0",
    "@std/testing": "jsr:@std/testing@^1.0.18"
  }
}
